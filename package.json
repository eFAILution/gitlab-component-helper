{
  "name": "gitlab-component-helper",
  "displayName": "GitLab Component Helper",
  "description": "Provides intellisense for GitLab CI components",
  "version": "0.10.4",
  "icon": "images/icon.png",
  "engines": {
    "node": ">=22.0.0",
    "vscode": ">=1.120.0"
  },
  "publisher": "eFAILution",
  "repository": {
    "type": "git",
    "url": "https://github.com/eFAILution/gitlab-component-helper.git"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:yaml",
    "onLanguage:shellscript",
    "workspaceContains:**/.gitlab-ci.yml",
    "workspaceContains:**/.gitlab-ci.yaml",
    "workspaceContains:**/.gitlab/**/*.yml",
    "workspaceContains:**/.gitlab/**/*.yaml"
  ],
  "contributes": {
    "languages": [
      {
        "id": "gitlab-ci",
        "aliases": [
          "GitLab CI",
          "gitlab-ci"
        ],
        "extensions": [
          ".gitlab-ci.yml",
          ".gitlab-ci.yaml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gitlab-ci",
        "scopeName": "source.yaml.gitlab-ci",
        "path": "./syntaxes/gitlab-ci.tmLanguage.json",
        "embeddedLanguages": {
          "source.yaml": "yaml"
        }
      }
    ],
    "configuration": {
      "title": "GitLab Component Helper",
      "properties": {
        "gitlabComponentHelper.componentSource": {
          "type": "string",
          "enum": [
            "local",
            "gitlab",
            "url"
          ],
          "default": "local",
          "description": "Source for component definitions"
        },
        "gitlabComponentHelper.gitlabUrl": {
          "type": "string",
          "default": "https://gitlab.com",
          "description": "GitLab instance URL"
        },
        "gitlabComponentHelper.gitlabProjectId": {
          "type": "string",
          "default": "",
          "description": "GitLab project ID containing component definitions"
        },
        "gitlabComponentHelper.gitlabToken": {
          "type": "string",
          "default": "",
          "description": "GitLab API access token (DEPRECATED - stored in plain text). Use the 'GitLab CI: Add Component Project/Group' command instead, which stores tokens encrypted via VS Code SecretStorage.",
          "deprecationMessage": "Tokens stored here live in plain text in settings.json. Run the 'GitLab CI: Add Component Project/Group' command to migrate to encrypted SecretStorage, then clear this field.",
          "markdownDescription": "**Deprecated:** Tokens stored here live in plain text in `settings.json`. Run the **GitLab CI: Add Component Project/Group** command instead - it stores tokens encrypted via VS Code SecretStorage. Once migrated, clear this field."
        },
        "gitlabComponentHelper.gitlabComponentsFilePath": {
          "type": "string",
          "default": "components.json",
          "description": "Path to components JSON file in GitLab repository"
        },
        "gitlabComponentHelper.componentsUrl": {
          "type": "string",
          "default": "",
          "description": "URL to a JSON file containing component definitions"
        },
        "gitlabComponentHelper.cacheTime": {
          "type": "number",
          "default": 3600,
          "description": "Cache time for components in seconds"
        },
        "gitlabComponentHelper.logLevel": {
          "type": "string",
          "enum": [
            "DEBUG",
            "INFO",
            "WARN",
            "ERROR"
          ],
          "default": "ERROR",
          "description": "Logging level for component service"
        },
        "gitlabComponentHelper.autoShowOutput": {
          "type": "boolean",
          "default": false,
          "description": "Automatically show output channel when log level changes (disabled during development)"
        },
        "gitlabComponentHelper.httpTimeout": {
          "type": "number",
          "default": 10000,
          "description": "HTTP request timeout in milliseconds"
        },
        "gitlabComponentHelper.retryAttempts": {
          "type": "number",
          "default": 3,
          "description": "Number of retry attempts for failed HTTP requests"
        },
        "gitlabComponentHelper.batchSize": {
          "type": "number",
          "default": 5,
          "description": "Number of components to process in parallel batches"
        },
        "gitlabComponentHelper.componentSources": {
          "type": "array",
          "default": [
            {
              "name": "GitLab CI Examples",
              "path": "gitlab-org/gitlab-foss",
              "gitlabInstance": "gitlab.com"
            },
            {
              "name": "OpenTofu Components",
              "path": "components/opentofu",
              "gitlabInstance": "gitlab.com"
            },
            {
              "name": "Detect Secrets Components",
              "path": "components/detect-secrets",
              "gitlabInstance": "gitlab.com"
            }
          ],
          "description": "GitLab repositories containing reusable CI/CD components",
          "items": {
            "type": "object",
            "required": [
              "name",
              "path"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for the component source"
              },
              "path": {
                "type": "string",
                "description": "GitLab project path (e.g., 'group/project')"
              },
              "gitlabInstance": {
                "type": "string",
                "default": "gitlab.com",
                "description": "GitLab instance hostname"
              },
              "discovery": {
                "type": "object",
                "description": "Per-source discovery overrides (uses gitlabComponentHelper.discovery.* defaults if omitted)",
                "properties": {
                  "templateRoots": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Repository directories to scan for components"
                  },
                  "maxDepth": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 3,
                    "description": "Subdirectory depth to recurse under each template root"
                  },
                  "filePatterns": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Filename globs (e.g. '*.yml'); path globs are not supported"
                  },
                  "templateFileNames": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Filenames recognised inside per-component subfolders (e.g. 'template.yml')"
                  }
                }
              }
            }
          }
        },
        "gitlabComponentHelper.discovery.templateRoots": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "templates"
          ],
          "description": "Repository directories scanned for components when cataloguing a source. Up to 5 entries.",
          "maxItems": 5
        },
        "gitlabComponentHelper.discovery.maxDepth": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 3,
          "description": "Subdirectory depth to recurse under each template root. 0 = root only, 1 = one level (default, matches GitLab spec)."
        },
        "gitlabComponentHelper.discovery.filePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "*.yml",
            "*.yaml"
          ],
          "description": "Filename globs identifying component template files. Filename only, no path globs."
        },
        "gitlabComponentHelper.discovery.templateFileNames": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "template.yml",
            "template.yaml"
          ],
          "description": "Filenames recognised inside per-component subfolders, e.g. 'templates/foo/template.yml'."
        },
        "gitlabComponentHelper.additionalFileGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra GitLab CI file globs, merged with the built-in defaults. Patterns match at any directory depth (e.g. 'ci/*.yml' is treated as '**/ci/*.yml')."
        }
      }
    },
    "commands": [
      {
        "command": "gitlab-component-helper.browseComponents",
        "title": "GitLab CI: Browse Components"
      },
      {
        "command": "gitlab-component-helper.refreshComponents",
        "title": "GitLab CI: Refresh Components Cache"
      },
      {
        "command": "gitlab-component-helper.updateCache",
        "title": "GitLab CI: Update Cache"
      },
      {
        "command": "gitlab-component-helper.resetCache",
        "title": "GitLab CI: Reset Cache"
      },
      {
        "command": "gitlab-component-helper.showCacheStatus",
        "title": "GitLab CI: Show Cache Status"
      },
      {
        "command": "gitlab-component-helper.debugCache",
        "title": "GitLab CI: Debug Cache (Detailed)"
      },
      {
        "command": "gitlab-component-helper.testProviders",
        "title": "GitLab CI: Test Providers"
      },
      {
        "command": "gitlabComponentHelper.addProjectToken",
        "title": "GitLab CI: Add Component Project/Group"
      },
      {
        "command": "gitlab-component-helper.showPerformanceStats",
        "title": "GitLab CI: Show Performance Statistics"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "gitlabComponentHelper.isCiFile",
          "command": "gitlab-component-helper.browseComponents",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "pretest": "npm run compile",
    "prepare": "husky",
    "test": "node tests/run-tests.js",
    "test:unit": "node tests/run-tests.js unit",
    "test:integration": "node tests/run-tests.js integration",
    "test:all": "node tests/run-tests.js && npm run test:extension-host",
    "pretest:extension-host": "npm run compile && tsc --project tsconfig.test.json",
    "test:extension-host": "node out-test/runTest.js",
    "release": "release-it",
    "release:beta": "release-it --config .release-it.beta.json",
    "release:main": "release-it --config .release-it.json",
    "release:beta:dry": "release-it --config .release-it.beta.json --dry-run",
    "release:main:dry": "release-it --config .release-it.json --dry-run",
    "setup:github-token": "./scripts/setup-github-token.sh",
    "release:version-only": "node scripts/version-bump.js",
    "release:dry": "node scripts/manual-release.js --dry-run",
    "release:local": "./scripts/release.sh",
    "release:local-only": "npm run release:manual",
    "release:manual": "node scripts/manual-release.js",
    "release:publish": "./scripts/publish-release.sh",
    "release:complete": "./scripts/release-and-publish.sh",
    "commitizen": "commitizen init cz-conventional-changelog --save-dev --save-exact --force"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.0",
    "@digitalroute/cz-conventional-changelog-for-jira": "^8.0.1",
    "@eslint/js": "^10.0.1",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-paginate-rest": "^14.0.0",
    "@release-it/conventional-changelog": "^10.0.4",
    "@types/glob": "^9.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.120.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vscode/test-electron": "^2.3.9",
    "commitizen": "^4.3.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "cz-emoji-conventional": "^1.1.0",
    "dateformat": "^5.0.3",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "husky": "^9.1.6",
    "is-ci": "^4.0.0",
    "js-yaml": "^4.1.1",
    "mocha": "^11.7.6",
    "npm-run-all": "^4.1.5",
    "release-it": "^19.2.4",
    "semver": "^7.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "keywords": [],
  "author": "eFAILution",
  "license": "MIT",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
