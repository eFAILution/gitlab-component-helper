{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2018",
    "outDir": "out",
    "lib": [
      "es2018",
      "dom"
    ],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "types": [
      "node",
      "vscode"
    ]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test",
    "out",
    "out-test",
    "tests"
  ]
}
