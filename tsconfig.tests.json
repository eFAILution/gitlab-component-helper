{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "types": [
      "node",
      "mocha"
    ]
  },
  "include": [
    "src/**/*",
    "tests/unit/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test",
    "out",
    "out-test",
    "tests/extension-host"
  ]
}
